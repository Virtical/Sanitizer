<main class="chat-panel" id="chatPanel">
    <div class="chat-header">
        <div class="profile-container">
            <button class="profile-chat-btn" id="profileChatBtn">
                <span class="profile-chat-text">Профиль общения</span>
                <i class="bi bi-chevron-down profile-chat-arrow"></i>
            </button>
            <div class="profile-dropdown" id="profileDropdown"></div>
        </div>
    </div>

    <div class="chat-empty-state" id="chatEmptyState">
        <h1 class="empty-title">Начните общение</h1>
        <div class="empty-input-container">
            <textarea class="empty-message-input" id="emptyMessageInput" placeholder="Введите текст..." rows="1"></textarea>
            <div class="input-buttons">
                <button class="input-btn" id="emptySanitizeToggleBtn">
                    <i class="bi bi-circle"></i>
                    <i class="bi bi-eye-slash sanitize-icon-overlay"></i>
                </button>
                <button class="empty-send-btn" id="emptySendBtn">
                    <i class="bi bi-arrow-up-circle-fill"></i>
                </button>
            </div>
        </div>
    </div>

    <div class="messages-area-wrapper" id="messagesWrapper" style="display: none;">
        <div class="messages-area" id="messagesArea"></div>
        <div class="input-container">
            <textarea class="message-input" id="messageInput" placeholder="Введите текст..." rows="1"></textarea>
            <div class="input-buttons">
                <button class="input-btn" id="sanitizeToggleBtn">
                    <i class="bi bi-circle"></i>
                    <i class="bi bi-eye-slash sanitize-icon-overlay"></i>
                </button>
                <button class="send-btn" id="sendBtn">
                    <i class="bi bi-arrow-up-circle-fill"></i>
                </button>
            </div>
        </div>
    </div>
</main>
