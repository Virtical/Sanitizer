@page "/"
@using Sanitizer.Components.Shared

<PageTitle>Sanitizer</PageTitle>

<div class="app-container" id="authenticatedContent" style="display: none;">
    <div class="main-layout">
        <DialogsPanel />
        <div class="right-panel-container">
            <ChatPanel />
            <ProfileCreationPanel />
            <ProfileEditingPanel />
